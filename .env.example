# NixOS DigitalOcean Base Image Builder
# Copy to .env and fill in your values

# REQUIRED: DigitalOcean API Token
# Get from: https://cloud.digitalocean.com/account/api/tokens
# Permissions: Read & Write
DIGITALOCEAN_TOKEN="your_digitalocean_api_token_here"

# OPTIONAL: Rclone Configuration (for automatic image upload)
# Configure rclone via environment variables (no rclone config file needed)
# See: https://rclone.org/docs/#environment-variables

# Rclone path (remote:bucket format)
# Remote name is fixed as "digitaloceanimages" (no hyphens for env var compatibility)
RCLONE_PATH="digitaloceanimages:digital-ocean-images"  # remote:bucket/path format

# Rclone configuration via environment variables
# Format: RCLONE_CONFIG_<REMOTENAME>_<OPTION>=<value>
# With our convention, remote name is "digitaloceanimages"

# Example for DigitalOcean Spaces (S3-compatible):
# RCLONE_CONFIG_DIGITALOCEANIMAGES_TYPE=s3
# RCLONE_CONFIG_DIGITALOCEANIMAGES_PROVIDER=DigitalOcean
# RCLONE_CONFIG_DIGITALOCEANIMAGES_ACCESS_KEY_ID=your_spaces_access_key
# RCLONE_CONFIG_DIGITALOCEANIMAGES_SECRET_ACCESS_KEY=your_spaces_secret_key
# RCLONE_CONFIG_DIGITALOCEANIMAGES_ENDPOINT=nyc3.digitaloceanspaces.com
# RCLONE_CONFIG_DIGITALOCEANIMAGES_ACL=private

# Example for AWS S3:
# RCLONE_CONFIG_DIGITALOCEANIMAGES_TYPE=s3
# RCLONE_CONFIG_DIGITALOCEANIMAGES_PROVIDER=AWS
# RCLONE_CONFIG_DIGITALOCEANIMAGES_ACCESS_KEY_ID=your_aws_access_key
# RCLONE_CONFIG_DIGITALOCEANIMAGES_SECRET_ACCESS_KEY=your_aws_secret_key
# RCLONE_CONFIG_DIGITALOCEANIMAGES_REGION=us-east-1

# Example for Backblaze B2:
# RCLONE_CONFIG_DIGITALOCEANIMAGES_TYPE=b2
# RCLONE_CONFIG_DIGITALOCEANIMAGES_ACCOUNT=your_account_id
# RCLONE_CONFIG_DIGITALOCEANIMAGES_KEY=your_application_key

# OPTIONAL: Custom image name
# If not set, script will generate: nixos-base-YYYYMMDD-HHMMSS
# NIXOS_IMAGE_NAME="nixos-base-custom"

# OPTIONAL: Image description
# IMAGE_DESCRIPTION="NixOS base image built on $(date)"

# OPTIONAL: Image tags (comma-separated)
# IMAGE_TAGS="nixos,base,digitalocean"

# OPTIONAL: DigitalOcean region for image upload
# Default: nyc3
# REGION="nyc3"

# OPTIONAL: SSH Public Keys to embed in the image
# Add one or more SSH public keys (one per line, no quotes)
# These will be added to the root user's authorized_keys
# Example:
# SSH_PUBLIC_KEYS="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... user@host"
# SSH_PUBLIC_KEYS="ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQ... user@host"
SSH_PUBLIC_KEYS=""

# OPTIONAL: Specific image path to use
# If not set, script will find newest image in result/ directory
# NIXOS_IMAGE_PATH="/path/to/specific/image.qcow2.gz"