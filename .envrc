# Direnv configuration for NixOS DigitalOcean Base Image Builder
# This file is automatically loaded when entering the directory

# Use flake.nix for development environment
use flake

# Load environment from .env if it exists
if [[ -f ".env" ]]; then
    echo "📋 Loading environment from .env"
    set -a
    . .env
    set +a
else
    echo "⚠️  .env not found"
    echo ""
    echo "To configure:"
    echo "  1. cp .env.example .env"
    echo "  2. Edit .env with your credentials"
    echo "  3. direnv reload"
fi

echo "NixOS DigitalOcean Base Image Builder environment loaded"
echo ""
echo "To build images:"
echo "  nix build .#digitalocean-image   - Build DigitalOcean image (.qcow2.gz)"
echo "  nix build .#raw-image            - Build raw image for testing (.img)"
echo ""
echo "Built images will be in result/ directory"